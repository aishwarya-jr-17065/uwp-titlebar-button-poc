<Page
    x:Class="UwpTitlebarButtonPoc.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="#121212">
        <Grid.RowDefinitions>
            <RowDefinition Height="40" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="CustomTitleBar" Grid.Row="0" Background="#1F1F1F" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="DragRegion" Grid.Column="0" MinHeight="32" />

            <Button x:Name="ChevronButton"
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    Margin="8,4,12,4"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Right"
                    Background="Transparent"
                    Foreground="White"
                    FontSize="14"
                    Content="˄"
                    Click="ChevronButton_Click"
                    ToolTipService.ToolTip="Custom title bar button" />
        </Grid>

        <StackPanel Grid.Row="1" Margin="24,24,24,24" Spacing="12">
            <TextBlock Text="UWP Title Bar Button POC"
                       FontSize="28"
                       FontWeight="SemiBold"
                       Foreground="White" />
            <TextBlock Text="The chevron button is placed just left of the system caption button area using SystemOverlayRightInset."
                       TextWrapping="WrapWholeWords"
                       Foreground="#DDFFFFFF" />
            <TextBlock x:Name="StatusText"
                       Text="Button has not been clicked."
                       Foreground="#FF8AD4FF" />
        </StackPanel>
    </Grid>
</Page>
